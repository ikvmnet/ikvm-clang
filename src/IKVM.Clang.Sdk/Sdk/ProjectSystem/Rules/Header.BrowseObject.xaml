<?xml version="1.0" encoding="utf-8"?>
<Rule
    Name="Header"
    DisplayName="Header File"
    PageTemplate="generic"
    Description="Properties for C/C++ header files."
    xmlns="http://schemas.microsoft.com/build/2009/properties">
    <Rule.DataSource>
        <DataSource Persistence="ProjectFile" ItemType="Header" HasConfigurationCondition="false" />
    </Rule.DataSource>

    <Rule.Categories>
        <Category Name="Advanced" DisplayName="Advanced" />
    </Rule.Categories>

    <BoolProperty 
        Name="CopyToIncludeDirectory"
        DisplayName="Copy to Include Directory"
        Description="Copy this header to the intermediate headers output folder and expose it to dependent projects."
        Category="Advanced"
        Default="true" />
</Rule>
