{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Objective-C++",
    "scopeName": "source.objcpp",
    "fileTypes": [ "mm" ],
    "patterns": [
        { "include": "source.objc" },
        { "include": "#cpp-keywords" },
        { "include": "#cpp-storage-types" }
    ],
    "repository": {
        "cpp-keywords": {
            "patterns": [
                {
                    "name": "keyword.control.cpp",
                    "match": "\\b(?:try|catch|throw|new|delete|this|operator|template|typename|namespace|using|explicit|friend|virtual|override|final|noexcept|constexpr|consteval|constinit|co_await|co_return|co_yield|static_assert|static_cast|dynamic_cast|reinterpret_cast|const_cast|nullptr|true|false)\\b"
                }
            ]
        },
        "cpp-storage-types": {
            "patterns": [
                {
                    "name": "storage.type.cpp",
                    "match": "\\b(?:class|struct|union|enum|auto|decltype|std::string|std::vector|std::map|std::set|std::shared_ptr|std::unique_ptr|std::weak_ptr)\\b"
                },
                {
                    "name": "storage.modifier.cpp",
                    "match": "\\b(?:public|protected|private|mutable|inline|virtual|static|extern|thread_local)\\b"
                }
            ]
        }
    }
}
