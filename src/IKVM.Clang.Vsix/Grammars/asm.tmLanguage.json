{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Assembly (GAS/LLVM)",
    "scopeName": "source.asm.gas",
    "fileTypes": [ "s", "S", "asm" ],
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#labels" },
        { "include": "#directives" },
        { "include": "#registers" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#mnemonics" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.hash.asm",
                    "match": "#.*$"
                },
                {
                    "name": "comment.line.semicolon.asm",
                    "match": ";.*$"
                },
                {
                    "name": "comment.line.double-slash.asm",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.asm",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.asm",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        { "name": "constant.character.escape.asm", "match": "\\\\." }
                    ]
                }
            ]
        },
        "labels": {
            "patterns": [
                {
                    "name": "entity.name.function.asm",
                    "match": "^\\s*[a-zA-Z_.][a-zA-Z0-9_.]*\\s*:"
                },
                {
                    "name": "entity.name.label.local.asm",
                    "match": "^\\s*[0-9]+\\s*:"
                }
            ]
        },
        "directives": {
            "patterns": [
                {
                    "name": "keyword.control.directive.asm",
                    "match": "^\\s*\\.(?:section|text|data|bss|align|balign|p2align|globl|global|local|weak|type|size|file|loc|cfi_startproc|cfi_endproc|cfi_def_cfa|cfi_def_cfa_offset|cfi_def_cfa_register|cfi_offset|cfi_restore|cfi_remember_state|cfi_restore_state|cfi_escape|cfi_signal_frame|cfi_lsda|cfi_personality|ascii|asciz|string|byte|short|hword|word|long|quad|octa|float|double|zero|space|fill|skip|rept|endr|macro|endm|include|extern|comm|lcomm|ifdef|ifndef|endif|if|else|endif|set|equ|equiv|eqv|altmacro|noaltmacro|purgem|irp|irpc|bundle_align_mode|bundle_lock|bundle_unlock|arch|cpu|thumb|arm|code|syntax|arm_func_start|arm_func_end|fnstart|fnend|save|vsave|cantunwind|handlerdata|ltorg|pool|req|unreq|tlsdescseq|movsp|setfp|pad|unwind_raw|even|sbttl|title|ident|version|subsection|pushsection|popsection|previous|linkonce|protected|hidden|internal|gnu_attribute|tls_common|xword|sleb128|uleb128)\\b"
                }
            ]
        },
        "registers": {
            "patterns": [
                {
                    "name": "variable.language.register.x86.asm",
                    "match": "%(?:rax|rbx|rcx|rdx|rsi|rdi|rbp|rsp|r8|r9|r10|r11|r12|r13|r14|r15|eax|ebx|ecx|edx|esi|edi|ebp|esp|ax|bx|cx|dx|si|di|bp|sp|al|bl|cl|dl|ah|bh|ch|dh|rip|eip|ip|rflags|eflags|flags|cs|ds|es|fs|gs|ss|xmm[0-9]+|ymm[0-9]+|zmm[0-9]+|mm[0-7]|st[0-7]|cr[0-9]+|dr[0-9]+)\\b"
                },
                {
                    "name": "variable.language.register.arm.asm",
                    "match": "\\b(?:r[0-9]+|r1[0-5]|sp|lr|pc|ip|fp|sl|sb|cpsr|spsr|x[0-9]+|x[12][0-9]|x30|xzr|wzr|w[0-9]+|w[12][0-9]|w30|v[0-9]+\\.[0-9]+[bBhHsS]|q[0-9]+|d[0-9]+|s[0-9]+|h[0-9]+|b[0-9]+)\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.asm",
                    "match": "\\$?0[xX][0-9a-fA-F]+"
                },
                {
                    "name": "constant.numeric.binary.asm",
                    "match": "\\$?0[bB][01]+"
                },
                {
                    "name": "constant.numeric.octal.asm",
                    "match": "\\$?0[0-7]+"
                },
                {
                    "name": "constant.numeric.decimal.asm",
                    "match": "\\$?-?[0-9]+(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.asm",
                    "match": "[+\\-*/&|^~<>!@]"
                }
            ]
        },
        "mnemonics": {
            "patterns": [
                {
                    "name": "keyword.other.mnemonic.asm",
                    "match": "^\\s+[a-zA-Z][a-zA-Z0-9]*(?:\\.[a-zA-Z0-9]+)*(?=\\s|$)"
                }
            ]
        }
    }
}
